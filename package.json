  "description": "Enterprise-grade Playwright + Cucumber BDD automation framework\r This is an enterprise-grade Playwright + Cucumber BDD automation framework, built for hands-on learning.",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:bdd": "npx cucumber-js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open"
  },
